# LUMII environment variables. Copy to .env.local and fill in.
# NEVER commit real secrets. .env.local is gitignored.

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database (Neon Postgres). DATABASE_URL = pooled (runtime); DIRECT_URL = direct (migrations).
DATABASE_URL=""
DIRECT_URL=""

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SIGNING_SECRET=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# AI (OpenRouter — https://openrouter.ai). Fund the account; keep a paid fallback.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="google/gemma-3-27b-it"
OPENROUTER_FALLBACK_MODEL="google/gemini-2.5-flash"

# Storage (Cloudflare R2 — private bucket)
CLOUDFLARE_R2_ENDPOINT=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET=""

# Quiz result token encryption (use a random 32+ char string)
QUIZ_TOKEN_SECRET=""
